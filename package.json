{
  "name": "@duydpdev/style-generator",
  "version": "1.6.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "style-gen": "dist/cli/index.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:cli": "tsdown src/cli/index.ts --format esm --out-dir dist/cli --banner.js '#!/usr/bin/env node'",
    "build:all": "yarn build && yarn build:cli",
    "commitlint": "commitlint",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0 --no-warn-ignored",
    "lint-staged": "lint-staged",
    "lint:fix": "yarn run lint --fix",
    "prettier": "prettier .",
    "prettier:fix": "prettier --write .",
    "prepare": "husky",
    "release": "semantic-release",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "vitest typecheck --run src/**/*.test-d.ts"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.3",
    "@commitlint/types": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.3.3",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "commitlint": "^20.4.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "semantic-release-yarn": "^3.0.2",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.21.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.4.0 || >=4.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duydpdev/style-generator.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint --fix --no-warn-ignored --max-warnings 0",
    "*.{json,md,yml,yaml,css}": "prettier --write"
  },
  "packageManager": "yarn@4.6.0",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chokidar": "^5.0.0"
  },
  "resolutions": {
    "minimatch": "^10.2.3",
    "tar": "^7.5.10"
  }
}
